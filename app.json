{
  "expo": {
    "name": "GO Tracker",
    "slug": "go-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00853F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ca.gotrackerapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00853F"
      },
      "package": "ca.gotrackerapp",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "go-tracker",
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GO Tracker uses your location to calculate drive time to nearby stations."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "GoTrackerWidget",
              "label": "GO Tracker — Next Train",
              "description": "Shows your next GO Transit departure at a glance",
              "minWidth": "320dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "privacyPolicyUrl": "https://ramyan03.github.io/go-transit-app/privacy.html",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe950534-6b7d-45b7-855f-6daed12b27f9"
      }
    }
  }
}
