# Get a free API key at https://www.metrolinx.com/en/aboutmetrolinx/open-data.aspx
METROLINX_API_KEY=your_key_here

# Port for the proxy server (default 3000)
PORT=3000

# Optional: Upstash Redis for production caching
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# CORS origin — set to your Expo dev URL or * for development
CORS_ORIGIN=*
